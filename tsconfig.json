{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "site/modules/**/*.js",
    "tests/**/*.js",
    "build/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "site/golf_manager.html",
    "site/index.html",
    "dist"
  ]
}
